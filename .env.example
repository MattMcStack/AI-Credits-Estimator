# Stripe secret key (required for pricing page). Must be a secret key (sk_test_... or sk_live_...),
# not a restricted key (rk_...). Get it from Stripe Dashboard → Developers → API keys.
STRIPE_API_KEY=sk_test_...

# Optional: Customer portal URL for "Customer Subscription Portal" button.
# If unset, the button is hidden. Example: https://billing.stripe.com/p/login/test_xxx
STRIPE_PORTAL_URL=
